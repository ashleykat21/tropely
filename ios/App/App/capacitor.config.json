{
	"appId": "com.nevora.tropely",
	"appName": "Tropely",
	"webDir": "artifacts/feltly/dist",
	"server": {
		"url": "https://usenevora.com",
		"androidScheme": "https",
		"iosScheme": "https",
		"cleartext": false
	},
	"ios": {
		"contentInset": "automatic"
	},
	"plugins": {
		"CapacitorUpdater": {
			"autoUpdate": true
		},
		"PushNotifications": {
			"presentationOptions": [
				"badge",
				"sound",
				"alert"
			]
		}
	},
	"packageClassList": []
}
