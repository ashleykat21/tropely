# ─── Tropely Mobile — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values.
# For EAS builds, set these in eas.json or via `eas secret:push`.

# Clerk publishable key — get from https://dashboard.clerk.com → API Keys
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# API server base domain (no trailing slash, no https://)
# Set this to your Render / Railway / Fly.io domain after deploying the API server.
# Example: EXPO_PUBLIC_DOMAIN=tropely-api.onrender.com
# Leave blank to hit the same origin (only works in web preview).
EXPO_PUBLIC_DOMAIN=
