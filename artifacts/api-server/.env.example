# ─── Tropely API Server — Environment Variables ───────────────────────────────
# Copy this file to .env for local development.
# On Render / Railway / Fly.io set these as environment variables in the dashboard.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase: Settings → Database → Connection string → URI
# Use the "Session mode" pooler URL (port 5432) for a long-running Express server.
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
# https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your web app domain).
CORS_ORIGIN=https://your-frontend.netlify.app

# ── AI (OpenAI-compatible) ────────────────────────────────────────────────────
# Used by the companion chat. Replace with your OpenAI key for self-hosting.
AI_INTEGRATIONS_OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ── Email (Resend) ────────────────────────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPPORT_EMAIL=support@yourdomain.com

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate once: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BExamplePublicKeyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=ExamplePrivateKeyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_SUBJECT=mailto:support@yourdomain.com

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
